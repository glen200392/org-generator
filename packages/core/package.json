{
  "name": "@orgchart/core",
  "version": "0.1.0",
  "private": true,
  "description": "Shared org chart core: data model, layout engine, renderer, export",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "build": "rm -f tsconfig.tsbuildinfo && tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "vitest": "^3.2.4"
  },
  "peerDependencies": {
    "jspdf": "^2.5.1",
    "pptxgenjs": "^3.12.0",
    "xlsx": "^0.18.5"
  }
}
